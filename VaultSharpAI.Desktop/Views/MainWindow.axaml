<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VaultSharpAI.Desktop.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="850" d:DesignHeight="650"
        x:Class="VaultSharpAI.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon ="/Assets/intellect.ico"
        Title="VaultSharpAI">

    <Grid RowDefinitions="Auto, *, Auto" Margin="15">
        
        <StackPanel Grid.Row="0" Spacing="10" Margin="0,0,0,15">
            <Grid ColumnDefinitions="*, 2*, 2*">
                <ComboBox Grid.Column="0" ItemsSource="{Binding SavedProfiles}" 
                          SelectedItem="{Binding SelectedProfile}" PlaceholderText="Провайдер..." HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ApiProfile">
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBox Grid.Column="1" Text="{Binding BaseUrl}" PlaceholderText="Base URL" Margin="5,0"/>
                <TextBox Grid.Column="2" Text="{Binding ApiKey}" PlaceholderText="API Key" PasswordChar="*"/>
            </Grid>
            
            <Grid ColumnDefinitions="*, Auto">
                <ComboBox Grid.Column="0" ItemsSource="{Binding AvailableModels}" SelectedItem="{Binding ModelName}" HorizontalAlignment="Stretch" PlaceholderText="Выберите модель"/>
                <Button Grid.Column="1" Content="Синхронизировать модели" Command="{Binding LoadModelsCommand}" Margin="10,0,0,0"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,5,0,0">
                <ToggleSwitch IsChecked="{Binding IsThinkingEnabled}" OnContent="Мышление ВКЛ" OffContent="Мышление ВЫКЛ"/>
                <ToggleSwitch IsChecked="{Binding IsDeepResearchEnabled}" OnContent="Deep Research ВКЛ" OffContent="Deep Research ВЫКЛ"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="5">
                    <TextBlock Text="Длина ответа (токенов):" VerticalAlignment="Center"/>
                    <NumericUpDown Value="{Binding MaxTokens}" Minimum="512" Maximum="16384" Increment="512" Width="130"/>
                </StackPanel>
            </StackPanel>
            
            <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsThinking}" Height="2"/>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="1" CornerRadius="5">
            <ListBox ItemsSource="{Binding Messages}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:ChatMessage">
                        <DockPanel Margin="5">
                            <TextBlock Text="{Binding Sender}" FontWeight="Bold" Width="110" DockPanel.Dock="Left"/>
                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap"/>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <StackPanel Grid.Row="2" Spacing="5" Margin="0,15,0,0">
            <TextBlock Text="{Binding AttachedFileInfo}" 
                       Foreground="Gray" 
                       FontSize="12" 
                       Margin="5,0,0,0"/>
            
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Button Grid.Column="0" Content="📎" Command="{Binding AttachFileCommand}" Margin="0,0,10,0" ToolTip.Tip="Прикрепить изображение или файл"/>
                <TextBox Grid.Column="1" Text="{Binding UserInput}" PlaceholderText="Введите промпт или прикрепите файл..."/>
                <Button Grid.Column="2" Content="Отправить" Command="{Binding SendMessageCommand}" Margin="10,0,0,0"/>
            </Grid>
        </StackPanel>
        
    </Grid>
</Window>